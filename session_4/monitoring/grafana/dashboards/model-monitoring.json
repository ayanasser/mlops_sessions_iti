{
  "uid": "session4-model-monitoring",
  "title": "Ride Duration — Model Monitoring",
  "description": "The four panels sketched in P_G_monitoring.py: request rate, p95 latency, prediction distribution, and PSI drift scores.",
  "tags": ["mlops", "session-4", "drift"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "editable": true,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request rate (req/s)",
      "description": "rate(api_request_latency_seconds_count[5m]) — histogram _count gives you a free request counter, so no separate Counter metric is needed.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (endpoint, status) (rate(api_request_latency_seconds_count[5m]))",
          "legendFormat": "{{endpoint}} · {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Latency p50 / p95 / p99",
      "description": "histogram_quantile over the _bucket series. p95 is the SLO line; the gap between p50 and p99 tells you whether slowness is systemic or tail-only.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(api_request_latency_seconds_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(api_request_latency_seconds_bucket[5m])))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(api_request_latency_seconds_bucket[5m])))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 0 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.5 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "heatmap",
      "title": "Predicted duration distribution",
      "description": "rate(model_prediction_duration_min_bucket[1h]) rendered as a heatmap — the shape shifting downward over days IS prediction drift, visible before any label arrives.",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (le) (rate(model_prediction_duration_min_bucket[1h]))",
          "format": "heatmap",
          "legendFormat": "{{le}}"
        }
      ],
      "options": {
        "calculate": false,
        "yAxis": { "unit": "m" },
        "color": { "mode": "scheme", "scheme": "Turbo", "steps": 64 }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "PSI drift score per feature",
      "description": "feature_psi_score, written by record_drift_scores() from the Airflow drift task. Red band starts at 0.25 — the retrain threshold from label_predicion_drift.py.",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "feature_psi_score",
          "legendFormat": "{{feature}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5,
            "thresholdsStyle": { "mode": "dashed+area" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 0.25 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Active model version",
      "description": "model_version_info gauge — labels carry the version and stage, so a deploy shows up as a step change you can correlate against the drift panels.",
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 17 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "model_version_info",
          "legendFormat": "{{version}} ({{stage}})",
          "instant": true
        }
      ],
      "options": {
        "textMode": "name",
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Predictions served (24h)",
      "description": "increase() over the histogram count. If this flatlines while the API is up, something upstream stopped calling you.",
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 17 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(model_prediction_duration_min_count[24h]))",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 0 },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Model API up",
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 17 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "up{job=\"model-api\"}", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red", "index": 0 },
                "1": { "text": "UP", "color": "green", "index": 1 }
              }
            }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "textMode": "value",
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    }
  ]
}
