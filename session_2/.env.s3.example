# .env.s3.example — copy to `.env` before running docker-compose.s3.yml:
#     cp .env.s3.example .env
# `docker compose -f docker-compose.s3.yml` auto-loads `.env` from this folder.
# NEVER commit the real `.env` (it holds secrets — it's covered by .gitignore).

# The bucket that will hold the artifacts (must already exist; no s3:// prefix).
MLFLOW_S3_BUCKET=my-mlflow-bucket

# AWS credentials the SERVER uses to read/write that bucket.
AWS_ACCESS_KEY_ID=AKIA...replace-me
AWS_SECRET_ACCESS_KEY=replace-me
AWS_DEFAULT_REGION=us-east-1

# Only for S3-compatible stores (MinIO / R2 / LocalStack). Leave EMPTY for AWS.
#   e.g. MinIO running locally:  http://minio:9000
MLFLOW_S3_ENDPOINT_URL=

# Host port for the MLflow UI (override if 5000 is taken).
MLFLOW_PORT=5000
