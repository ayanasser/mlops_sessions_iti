# .env.gcs.example — copy to `.env` before running docker-compose.gcs.yml:
#     cp .env.gcs.example .env
# `docker compose -f docker-compose.gcs.yml` auto-loads `.env` from this folder.
# NEVER commit the real `.env` (it holds config paths — it's covered by .gitignore).

# The bucket that will hold the MLflow artifacts (must already exist; no gs:// prefix).
# Artifacts land under gs://$MLFLOW_GCS_BUCKET/mlflow/…
MLFLOW_GCS_BUCKET=mlops-session2-iti

# Path (ON THE HOST) to the GCP service-account key JSON the SERVER uses to
# read/write that bucket. The key needs roles/storage.objectAdmin on the bucket.
# This file is bind-mounted read-only into the container at /gcp/key.json.
# Keep it out of git — .gitignore already excludes gcp-key.json.
GOOGLE_APPLICATION_CREDENTIALS=./gcp-key.json

# Host port for the MLflow UI (override if 5000 is taken).
MLFLOW_PORT=5000
