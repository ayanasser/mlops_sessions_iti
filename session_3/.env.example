# ── Airflow local-dev environment ─────────────────────────────────────────
# Consumed by docker-compose.yaml. Copy to .env and fill in your own values:
#
#   cp .env.example .env
#
# Generate the two secrets with:
#   FERNET_KEY:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   JWT_SECRET:  openssl rand -hex 32

# UID that Airflow containers run as. 50000 is the image's built-in `airflow`
# user, which avoids root-owned files in the mounted logs/ dir on Linux.
# (On macOS/Docker Desktop ownership is handled by the VM, so this is cosmetic.)
AIRFLOW_UID=50000

# Image tag — pinned to the latest Airflow 3.x. The Dockerfile extends this.
AIRFLOW_IMAGE_NAME=mlops-airflow:3.3.0

# Fernet key encrypts connection passwords/variables in the metadata DB.
FERNET_KEY=

# Secret used to sign the JWT tokens the api-server issues to workers.
AIRFLOW__API_AUTH__JWT_SECRET=

# Admin login created by airflow-init (open http://localhost:8080).
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow
